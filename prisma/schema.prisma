generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lojista {
  id              String   @id @default(cuid())
  nome            String
  email           String   @unique
  senha           String
  slug            String   @unique
  nomeNegocio     String
  tema            String   @default("generico")
  selosParaGanhar Int      @default(10)
  recompensa      String   @default("1 item grátis")
  ticketMedio     Float    @default(0)
  whatsapp        String?
  regras          String?
  horario         String?
  endereco        String?
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  resetToken      String?
  resetTokenExp   DateTime?
  cartoes         Cartao[]
}

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  email     String?  @unique
  telefone  String?
  createdAt DateTime @default(now())
  cartoes   Cartao[]
}

model Cartao {
  id            String    @id @default(cuid())
  lojistaId     String
  clienteId     String
  token         String    @unique
  selos         Int       @default(0)
  totalCarimbos Int       @default(0)
  resgates      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lojista       Lojista   @relation(fields: [lojistaId], references: [id])
  cliente       Cliente   @relation(fields: [clienteId], references: [id])
  carimbos      Carimbo[]

  @@unique([lojistaId, clienteId])
}

model Carimbo {
  id        String   @id @default(cuid())
  cartaoId  String
  descricao String?
  valor     Float?
  createdAt DateTime @default(now())
  cartao    Cartao   @relation(fields: [cartaoId], references: [id])
}
