# ── NewPerks — variáveis de produção (VPS) ──────────────────────
# Copie este arquivo pra ".env" NA VPS (ao lado do docker-compose.yml)
# e preencha os valores. NÃO comitar o .env preenchido.

# Banco (o compose cria o Postgres com esses dados)
POSTGRES_USER=newperks
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
POSTGRES_DB=newperks

# Segredo do NextAuth — gere com: openssl rand -base64 32
NEXTAUTH_SECRET=TROQUE_POR_UM_SEGREDO_ALEATORIO

# URL pública do app (o domínio que vai apontar pra VPS)
NEXTAUTH_URL=https://fidelix.newflowsys.cloud

# Email (Módulo 3 — deixe vazio por enquanto; sem isso o link
# aparece na tela em vez de ser enviado por email)
RESEND_API_KEY=
EMAIL_FROM=NewPerks <onboarding@resend.dev>
